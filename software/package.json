{
  "name": "eddi",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "scripts": {
    "dev": "npm run dev --workspace=packages/web",
    "build": "npm run build --workspace=packages/web",
    "deploy:web": "npm run build --workspace=packages/web && cd infra && npx wrangler deploy",
    "deploy:backend": "npm run deploy --workspace=packages/backend"
  }
}
